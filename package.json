{
  "name": "personal-website",
  "version": "1.0.0",
  "description": "Static personal website and project archive for agreddy.com, built with HTML, CSS, and JavaScript.",
  "scripts": {
    "dev": "python3 -m http.server 8080",
    "format": "prettier --write .",
    "lint:readme": "remark README.md",
    "prepare": "husky",
    "vendor:primer": "node scripts/vendor-primer.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agopalareddy/personal-website.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/agopalareddy/personal-website/issues"
  },
  "homepage": "https://github.com/agopalareddy/personal-website#readme",
  "lint-staged": {
    "*.{html,css,js,json,md}": "prettier --write"
  },
  "remarkConfig": {
    "plugins": [
      "standard-readme-preset"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@primer/octicons": "^19.29.2",
    "@primer/primitives": "^11.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "remark-cli": "^12.0.1",
    "standard-readme-preset": "^1.0.11"
  }
}
